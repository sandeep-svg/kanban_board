{
  "name": "kanban_board",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css": "npx tailwindcss -i ./app/assets/stylesheets/input.css -o ./app/assets/builds/application.css --minify",
    "build:css:watch": "npx tailwindcss -i ./app/assets/stylesheets/input.css -o ./app/assets/builds/application.css --watch",
    "build:js": "node esbuild.config.js",
    "build": "npm run build:css && npm run build:js && npm run copy",
    "copy": "node -e \"const fs=require('fs');fs.copyFileSync('app/assets/builds/application.js','public/assets/application.js');fs.copyFileSync('app/assets/builds/application.css','public/assets/application.css');console.log('Copied to public/assets')\"",
    "dev": "npm run build:js && npm run build:css:watch"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^17.0.0",
    "date-fns": "^4.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "esbuild": "^0.24.2",
    "tailwindcss": "^3.4.17"
  }
}